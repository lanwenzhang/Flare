#version 450
layout(set = 0, binding = 1) uniform lightParams{
    vec4 lightDir;
    float intensity;
    float lightRadius;
    uint numFrames;
};

layout(set = 1, binding = 6) uniform GTAOParams {
    vec2  resolution;     
    vec2  depthUnpack; 
    vec2  ndcToViewMul;            
    vec2  ndcToViewAdd;     
    vec2  ndcToViewMul_x_PixelSize;

    float effectRadius;
    float effectFalloffRange;
    float radiusMultiplier;
    float sampleDistributionPower;

    float thinOccluderCompensation;
    float depthMipSamplingOffset;  
    float finalValuePower;   
    float denoiseBlurBeta;

    uint  frameIndex;
    uint  sliceCount;       
    uint  stepsPerSlice;
    uint  depthMipLevels;

    mat4 worldToView;
};
layout(set = 2, binding = 0) uniform sampler2D uDepth;
layout(set = 2, binding = 1) uniform sampler2D uNormal;
layout(set = 2, binding = 2) uniform usampler2D uHilbertLUT;
layout(set = 2, binding = 3, r8ui) uniform writeonly uimage2D uAORawOut;
layout(set = 2, binding = 4, r8) uniform writeonly image2D uEdgesOut;

layout(local_size_x = 8, local_size_y = 8, local_size_z = 1) in;

const float kPi     = 3.14159265358979323846;
const float kPiHalf = 1.57079632679489661923;

vec2 viewportPixelSize(){
    return 1.0 / resolution;
}

vec3 computeViewspacePosition(vec2 screenPos, float viewspaceDepth){
    vec3 ret;
    ret.xy = (ndcToViewMul * screenPos + ndcToViewAdd) * viewspaceDepth;
    ret.z  = viewspaceDepth;
    return ret;
}

vec4 calculateEdges(float centerZ, float leftZ, float rightZ, float topZ, float bottomZ){
    vec4 edgesLrtb = vec4(leftZ, rightZ, topZ, bottomZ) - centerZ;

    float slopeLr = (edgesLrtb.y - edgesLrtb.x) * 0.5;
    float slopeTb = (edgesLrtb.w - edgesLrtb.z) * 0.5;

    vec4 edgesSlopeAdjusted = edgesLrtb + vec4(slopeLr, -slopeLr, slopeTb, -slopeTb);
    edgesLrtb = min(abs(edgesLrtb), abs(edgesSlopeAdjusted));

    return clamp(1.25 - edgesLrtb / (centerZ * 0.011), 0.0, 1.0);
}

float packEdges(vec4 edgesLrtb){
    vec4 q = round(clamp(edgesLrtb, 0.0, 1.0) * 2.9);
    return dot(q, vec4(64.0/255.0, 16.0/255.0, 4.0/255.0, 1.0/255.0));
}

